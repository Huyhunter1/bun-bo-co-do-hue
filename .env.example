# Environment Variables
# Copy this file to .env.local (local) or set these in your deploy platform

# MongoDB Configuration
# Local example: mongodb://127.0.0.1:27017
# Atlas example: mongodb+srv://<user>:<password>@<cluster-url>/?retryWrites=true&w=majority&appName=<app>
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=bun_bo_hue_co_do
# Optional: Atlas target URI used by migration script
TARGET_MONGODB_URI=mongodb+srv://<user>:<password>@<cluster-url>/?retryWrites=true&w=majority&appName=<app>

# JWT Secret (change in production)
JWT_SECRET=replace_with_strong_secret_key
JWT_EXPIRES_IN=7d

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# SMS Configuration
SMS_ENABLED=false
SMS_PROVIDER=infobip
INFOBIP_API_KEY=
INFOBIP_BASE_URL=https://api.infobip.com
INFOBIP_SENDER=InfoSMS
SPEEDSMS_ACCESS_TOKEN=
ESMS_API_KEY=
ESMS_SECRET_KEY=
SMS_BRAND_NAME=
